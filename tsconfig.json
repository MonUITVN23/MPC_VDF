{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["es2020", "dom"],
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "*": ["node_modules/*", "contracts/node_modules/*"],
      "hardhat": ["contracts/node_modules/hardhat"]
    }
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules", "contracts/node_modules"]
}
