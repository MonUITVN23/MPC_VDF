{
  "name": "mpc-vdf-zk-circuits",
  "version": "1.0.0",
  "description": "ZK-SNARK circuits for BLS12-381 signature commitment verification",
  "private": true,
  "dependencies": {
    "circomlib": "^2.0.5",
    "snarkjs": "^0.7.5"
  },
  "scripts": {
